pipeline{
    agent {
        label 'dev'
    }
    tools {
        jdk 'java-11'
        maven 'maven'

    }
    stages{
        stage('git checkout'){
            steps {
                git branch: 'main', url: 'https://github.com/praveenkumarchannappagoudra/test-1.git'
            }
        }
        stage('compile'){
            steps {
                sh "mvn compile"

            }
        }
        stage('build'){
            steps {
                sh "mvn package"
            }
        }


    }

}
